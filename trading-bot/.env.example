# ============================================
# TELEGRAM BOT CONFIGURATION
# ============================================
# Lấy từ @BotFather trên Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Chat ID của bạn hoặc group chat (dùng @userinfobot để lấy)
TELEGRAM_CHAT_ID=your_chat_id_here

# ============================================
# BINANCE API CONFIGURATION (chỉ đọc - Read Only)
# ============================================
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# ============================================
# TRADING CONFIGURATION
# ============================================
# Hướng giao dịch quét tín hiệu: BOTH (mặc định), LONG_ONLY, hoặc SHORT_ONLY
TRADE_DIRECTION=BOTH

# Symbols cần theo dõi (phân tách bằng dấu phẩy)
SYMBOLS=BTC/USDT,XAU/USDT,ETH/USDT

# Khung thời gian chính để quét tín hiệu
TIMEFRAME_ENTRY=5m
TIMEFRAME_CONTEXT=4h
TIMEFRAME_DAILY=1d

# Vốn tài khoản (USD)
ACCOUNT_BALANCE=1000

# Rủi ro tối đa mỗi lệnh (%)
MAX_RISK_PERCENT=2

# R:R tối thiểu
MIN_RR_RATIO=2.0

# Chu kỳ quét tín hiệu (giây)
SCAN_INTERVAL_SECONDS=300
