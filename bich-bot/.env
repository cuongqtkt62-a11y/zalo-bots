# ============================================================
# Zalo AI Assistant (Zalo Cá Nhân) — Environment Variables
# ============================================================
# HƯỚNG DẪN:
#   1. Copy file này thành .env:  cp .env.example .env
#   2. Điền GEMINI_API_KEY (bắt buộc)
#   3. Các config khác để mặc định cũng OK
# ============================================================

# ── AI Engine Configuration ──────────────────────────────
# Chọn: "gemini" hoặc "openai"
AI_PROVIDER=gemini

# Chế độ của Skill 06: "static" (sử dụng 20 kịch bản mẫu) hoặc "ai" (AI tự sinh bài đăng mới dựa trên 100 ý tưởng Ebook)
CONTENT_CREATOR_MODE=static

# Google Gemini API Key (BẮT BUỘC)
# Lấy miễn phí tại: https://aistudio.google.com/apikey
GEMINI_API_KEY=AQ.Ab8RN6IKn1NtEBrsHWCQpBiZ9gHXALNSQdHGlvpY9J6eWMhtCA

# Gemini model (mặc định: gemini-2.0-flash — nhanh và miễn phí)
GEMINI_MODEL=gemini-2.5-flash

# OpenAI / Custom OpenAI API Key (tùy chọn, chỉ cần nếu AI_PROVIDER=openai)
# Cấu hình cho Groq:
OPENAI_API_KEY=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
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile

# ── Zalo Configuration ───────────────────────────────────
# File lưu credentials sau khi scan QR (tự động tạo)
ZALO_CREDENTIALS_PATH=./zalo-credentials.json

# Tên hiển thị trong log
ZALO_ACCOUNT_NAME=Lưu Bích Assistant

# ── Rate Limiting (Chống phát hiện bot) ───────────────────
# Delay trước khi reply (milliseconds) — giả lập thời gian đánh máy
MIN_REPLY_DELAY=1500
MAX_REPLY_DELAY=4000

# Số tin nhắn tối đa gửi đi mỗi phút
MAX_MSG_PER_MIN=8

# ── Database (Tùy chọn) ──────────────────────────────────
# Giai đoạn 1 dùng JSON file, không cần DB
DB_ENABLED=false

# Nếu muốn dùng PostgreSQL (giai đoạn 2):
# DB_ENABLED=true
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=zalo_assistant
# DB_USER=zalo_admin
# DB_PASSWORD=your_password

# ── n8n (Tùy chọn) ───────────────────────────────────────
N8N_ENABLED=false
# N8N_WEBHOOK_URL=http://localhost:5678/webhook

# ── Environment ──────────────────────────────────────────
NODE_ENV=production

# ── Admin Authorization ──────────────────────────────────
# Zalo ID của Admin (chỉ tài khoản này mới dùng được lệnh #id,...)
ADMIN_ZALO_ID=690136550523054881,6114894381239760462

# ── Telegram Notification (Skill 03, 04, 08, 09) ─────────
TELEGRAM_BOT_TOKEN=8623878114:AAEvt-qcOGDx2Cykpw-Z-786GLCPZEe3ZKM
TELEGRAM_CHAT_ID=1389725436

# ── Số điện thoại trợ lý ─────────────────────────────────
ASSISTANT_PHONE=0944703139
